public class QuantityMeasurementApp {

    // ===== ENUM WITH ALL UNITS =====
    enum LengthUnit {
        FEET(1.0),
        INCH(1.0 / 12.0),
        YARD(3.0),
        CENTIMETER(0.0328084); // 1 cm = 0.0328084 feet

        private final double toFeetFactor;

        LengthUnit(double toFeetFactor) {
            this.toFeetFactor = toFeetFactor;
        }

        public double toFeet(double value) {
            return value * toFeetFactor;
        }
    }

    // ===== GENERIC QUANTITY CLASS =====
    static class Quantity {
        private final double value;
        private final LengthUnit unit;

        public Quantity(double value, LengthUnit unit) {
            if (unit == null) {
                throw new IllegalArgumentException("Unit cannot be null");
            }
            this.value = value;
            this.unit = unit;
        }

        private double toFeet() {
            return unit.toFeet(value);
        }

        @Override
        public boolean equals(Object obj) {
            if (this == obj) return true;
            if (obj == null || getClass() != obj.getClass()) return false;

            Quantity other = (Quantity) obj;

            return Double.compare(this.toFeet(), other.toFeet()) == 0;
        }
    }

    // ===== MAIN METHOD =====
    public static void main(String[] args) {

        // Yard comparisons
        System.out.println("1 Yard == 3 Feet: " +
                new Quantity(1, LengthUnit.YARD)
                        .equals(new Quantity(3, LengthUnit.FEET)));

        System.out.println("1 Yard == 36 Inch: " +
                new Quantity(1, LengthUnit.YARD)
                        .equals(new Quantity(36, LengthUnit.INCH)));

        // Centimeter comparisons
        System.out.println("1 cm == 0.393701 inch: " +
                new Quantity(1, LengthUnit.CENTIMETER)
                        .equals(new Quantity(0.393701, LengthUnit.INCH)));

        // Same unit
        System.out.println("2 Yard == 2 Yard: " +
                new Quantity(2, LengthUnit.YARD)
                        .equals(new Quantity(2, LengthUnit.YARD)));

        // Complex (transitive)
        Quantity a = new Quantity(2, LengthUnit.YARD);
        Quantity b = new Quantity(6, LengthUnit.FEET);
        Quantity c = new Quantity(72, LengthUnit.INCH);

        System.out.println("Transitive (2Y = 6F = 72I): " +
                (a.equals(b) && b.equals(c) && a.equals(c)));

        // Edge cases
        System.out.println("Null check: " +
                new Quantity(1, LengthUnit.FEET).equals(null));
    }
}